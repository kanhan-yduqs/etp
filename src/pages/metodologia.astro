---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout title="Metodologia">
  <section class="py-16 md:py-24">
    <Container>
      <div class="max-w-3xl">
        <span class="font-label text-xs font-medium uppercase tracking-[0.2em] text-on-surface-variant">Transparência</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-2 text-primary">Metodologia</h1>
        <div class="mt-8 space-y-6 text-on-surface-variant text-base leading-relaxed">
          <p>Conteúdo detalhado será adicionado no Sprint 0D com dados do metadata.json.</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
