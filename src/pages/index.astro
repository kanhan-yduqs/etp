---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import BigNumber from '../components/BigNumber.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SourceNote from '../components/SourceNote.astro';
import LineChart from '../components/charts/LineChart.astro';
import BarChart from '../components/charts/BarChart.astro';
import ChoroplethMap from '../components/charts/ChoroplethMap.astro';
import ChartActions from '../components/charts/ChartActions.astro';
import AnalysisCard from '../components/AnalysisCard.astro';
import PolicyCard from '../components/PolicyCard.astro';
import {
  getSerieTemporal,
  getMatriculasPorRegiao,
  getMatriculasPorUF,
  getLatestYear,
  getComparacoesInternacionais,
  formatNumber,
  formatPercent,
  calcGrowthPercent,
} from '../lib/data';
import { getCollection } from 'astro:content';

// --- Dados calculados em build time ---
const serie = getSerieTemporal();
const latestYear = getLatestYear();
const latest = serie.find(s => s.ano === latestYear)!;
const previous = serie.find(s => s.ano === latestYear - 1)!;
const oldest = serie[0];

const growthYoY = calcGrowthPercent(latest.total, previous.total);
const growthPublicaYoY = calcGrowthPercent(latest.publica, previous.publica);
const growth5y = calcGrowthPercent(latest.total, oldest.total);

// --- Gráfico: Série temporal ---
const lineChartData = JSON.stringify({
  labels: serie.map(s => s.ano.toString()),
  datasets: [
    {
      label: 'Total',
      data: serie.map(s => s.total),
      borderColor: '#0D3B4C',
      backgroundColor: 'rgba(13, 59, 76, 0.1)',
      fill: true,
      tension: 0.3,
      borderWidth: 2.5,
      pointRadius: 4,
      pointBackgroundColor: '#0D3B4C',
    },
    {
      label: 'Rede Pública',
      data: serie.map(s => s.publica),
      borderColor: '#476800',
      backgroundColor: 'rgba(71, 104, 0, 0.05)',
      fill: true,
      tension: 0.3,
      borderWidth: 2,
      pointRadius: 3,
      pointBackgroundColor: '#476800',
    },
    {
      label: 'Rede Privada',
      data: serie.map(s => s.privada),
      borderColor: '#2d6195',
      backgroundColor: 'rgba(45, 97, 149, 0.05)',
      fill: true,
      tension: 0.3,
      borderWidth: 2,
      pointRadius: 3,
      pointBackgroundColor: '#2d6195',
    },
  ],
});

// --- Gráfico: Matrículas por região ---
const regioes = getMatriculasPorRegiao(latestYear).sort((a, b) => b.total - a.total);
const barChartData = JSON.stringify({
  labels: regioes.map(r => r.regiao),
  datasets: [
    {
      label: `Matrículas ${latestYear}`,
      data: regioes.map(r => r.total),
      backgroundColor: ['#0D3B4C', '#476800', '#4a6d00', '#2d6195', '#8da1b9'],
      borderRadius: 4,
    },
  ],
});

// --- Content collections ---
const analises = await getCollection('analises');
const recentAnalises = analises.sort((a, b) => a.data.date > b.data.date ? -1 : 1).slice(0, 3);
const politicas = await getCollection('politicas');
const politicasAtivas = politicas.filter(p => p.data.status !== 'encerrada').slice(0, 3);

// --- Comparações ---
const comparacoes = getComparacoesInternacionais();
const brasil = comparacoes.find(c => c.iso3 === 'BRA')!;
const ocde = comparacoes.find(c => c.iso3 === 'OCDE')!;

// --- Mapa: dados por UF ---
const ufsMap = getMatriculasPorUF(latestYear);
const mapDataObj: Record<string, number> = {};
ufsMap.forEach(u => { mapDataObj[u.sigla_uf] = u.total; });
const mapData = JSON.stringify(mapDataObj);
---

<BaseLayout title="Home">
  <!-- Schema.org Dataset -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Matrículas da Educação Profissional e Tecnológica no Brasil",
    "description": "Dados de matrículas em educação profissional técnica de nível médio no Brasil por UF, região, rede e modalidade, derivados das Sinopses Estatísticas da Educação Básica do INEP/MEC.",
    "url": "https://observatorio-etp.pages.dev/painel/",
    "temporalCoverage": `${oldest.ano}/${latestYear}`,
    "spatialCoverage": { "@type": "Place", "name": "Brasil" },
    "creator": { "@type": "Person", "name": "Marcelo Kanhan" },
    "provider": { "@type": "Organization", "name": "Observatório Nacional ETP" },
    "license": "https://creativecommons.org/licenses/by/4.0/",
    "isBasedOn": "https://www.gov.br/inep/pt-br/acesso-a-informacao/dados-abertos/sinopses-estatisticas",
    "measurementTechnique": "Sinopses Estatísticas derivadas do Censo Escolar da Educação Básica (INEP/MEC)",
    "variableMeasured": [
      "Matrículas por modalidade (integrada, concomitante, subsequente)",
      "Matrículas por rede (federal, estadual, municipal, privada)",
      "Matrículas por Unidade da Federação",
      "Matrículas por região geográfica"
    ]
  })} />

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <Container class="py-16 md:py-20 relative z-10 w-full">
      <div class="max-w-5xl mx-auto space-y-8 text-center flex flex-col items-center">
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight text-primary leading-[1.05]">
          O futuro do Ensino Técnico no Brasil, <span class="text-secondary">em dados.</span>
        </h1>
        <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-3xl">
          Traduzimos a complexidade da Educação Profissional e Tecnológica em conhecimento estratégico para transformar políticas públicas em realidade nacional.
        </p>
        <div class="pt-6 flex flex-wrap justify-center gap-4">
          <a href="/painel/" class="px-8 py-4 editorial-gradient text-on-primary font-semibold rounded-md hover:opacity-90 transition-all shadow-lg">
            Explorar Dados Atuais
          </a>
          <a href="/metodologia/" class="px-8 py-4 border border-outline-variant text-primary font-semibold rounded-md hover:bg-surface-container-low transition-all">
            Ver Metodologia
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Big Numbers -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader label="Indicadores Nacionais" title="Panorama Estratégico">
        <div class="text-on-surface-variant font-label text-sm italic">
          Última atualização: Censo Escolar {latestYear}
        </div>
      </SectionHeader>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <BigNumber
          value={formatNumber(latest.total)}
          label="Total Matrículas EPT"
          trend="up"
          trendValue={`+${formatPercent(growthYoY)} vs ${latestYear - 1}`}
        />
        <BigNumber
          value={formatNumber(latest.publica)}
          label="Rede Pública"
          trend="up"
          trendValue={`+${formatPercent(growthPublicaYoY)} vs ${latestYear - 1}`}
        />
        <BigNumber
          value={formatNumber(latest.estadual)}
          label="Rede Estadual"
          trend="up"
          trendValue="maior rede"
        />
        <BigNumber
          value={`+${formatPercent(growth5y, 0)}`}
          label={`Crescimento ${oldest.ano}–${latestYear}`}
          trend="up"
          trendValue={`${serie.length} anos`}
        />
      </div>

      <SourceNote source="Sinopses Estatísticas da Educação Básica — INEP/MEC" year={`${oldest.ano}–${latestYear}`} />
    </Container>
  </section>

  <!-- Série Temporal -->
  <section class="py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Evolução de Matrículas Técnicas"
        subtitle="Série temporal de matrículas na Educação Profissional e Tecnológica por tipo de rede."
      />

      <div class="bg-surface-container-lowest p-4 md:p-8 rounded-xl">
        <LineChart chartId="serie-temporal" chartData={lineChartData} yLabel="Matrículas" />
        <ChartActions chartId="serie-temporal" csvData={lineChartData} csvFilename="serie-temporal-ept.csv" embedPath="embed/serie-temporal" />
      </div>

      <SourceNote source="Sinopses Estatísticas da Educação Básica — INEP/MEC" year={`${oldest.ano}–${latestYear}`} />
    </Container>
  </section>

  <!-- Matrículas por Região -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Distribuição Regional"
        subtitle={`Matrículas da Educação Profissional por região do Brasil em ${latestYear}.`}
      />

      <div class="bg-surface-container-lowest p-4 md:p-8 rounded-xl">
        <BarChart chartId="por-regiao" chartData={barChartData} horizontal={true} height="320px" />
        <ChartActions chartId="por-regiao" csvData={barChartData} csvFilename="distribuicao-regional-ept.csv" embedPath="embed/distribuicao-regional" />
      </div>

      <SourceNote source="Sinopses Estatísticas da Educação Básica — INEP/MEC" year={latestYear} />
    </Container>
  </section>

  <!-- Mapa Nacional -->
  <section class="py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Distribuição Territorial da ETP"
        subtitle={`Matrículas da Educação Profissional por Unidade da Federação em ${latestYear}. Clique em um estado para ver seu perfil.`}
      />

      <ChoroplethMap
        mapId="mapa-brasil"
        mapData={mapData}
        legendLabel="Matrículas"
        height="520px"
      />

      <SourceNote source="Sinopses Estatísticas da Educação Básica — INEP/MEC" year={latestYear} />
    </Container>
  </section>

  <!-- Políticas em andamento -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        label="Políticas Públicas"
        title="Monitoramento de Políticas"
      >
        <a href="/politicas/" class="font-label text-sm text-secondary hover:underline">Ver todas →</a>
      </SectionHeader>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {politicasAtivas.map(p => (
          <PolicyCard
            title={p.data.title}
            status={p.data.status}
            excerpt={p.data.excerpt}
            href={`/politicas/${p.id}/`}
            progressLabel={p.data.progressLabel}
            progressValue={p.data.progressValue}
          />
        ))}
      </div>
    </Container>
  </section>

  <!-- Comparações internacionais teaser -->
  <section class="py-16 md:py-24">
    <Container>
      <SectionHeader
        label="Contexto Internacional"
        title="Brasil no Cenário Global"
      >
        <a href="/comparacoes/" class="font-label text-sm text-secondary hover:underline">Ver comparações →</a>
      </SectionHeader>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <BigNumber
          value={`${formatPercent(brasil.vetEnrollmentRate, 1)}`}
          label="Jovens em VET — Brasil"
          trend="down"
          trendValue={`vs ${formatPercent(ocde.vetEnrollmentRate, 0)} média OCDE`}
        />
        <BigNumber
          value={`${formatPercent(brasil.employability12m, 0)}`}
          label="Empregabilidade 12m"
        />
        <BigNumber
          value={`${brasil.publicInvestment}% PIB`}
          label="Investimento Público"
          trendValue={`vs ${ocde.publicInvestment}% OCDE`}
        />
      </div>
    </Container>
  </section>

  <!-- Análises -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        label="Análises em Destaque"
        title="Aprofunde sua Pesquisa"
      >
        <a href="/analises/" class="font-label text-sm text-secondary hover:underline">Ver todas →</a>
      </SectionHeader>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentAnalises.map(a => (
          <AnalysisCard
            title={a.data.title}
            category={a.data.category}
            date={a.data.date}
            excerpt={a.data.excerpt}
            href={`/analises/${a.id}/`}
            readTime={a.data.readTime}
          />
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
