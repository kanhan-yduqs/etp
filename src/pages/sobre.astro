---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout title="Sobre" activePage="sobre">
  <section class="py-16 md:py-24">
    <Container>
      <div class="max-w-3xl">
        <span class="font-label text-xs font-medium uppercase tracking-[0.2em] text-on-surface-variant">Sobre o Observatório</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-2 text-primary">Observatório Nacional ETP</h1>
        <div class="mt-8 space-y-6 text-on-surface-variant text-lg leading-relaxed">
          <p>
            O Observatório Nacional do Ensino Técnico e Profissionalizante é uma plataforma digital de referência que consolida, visualiza e analisa dados sobre a educação profissional técnica de nível médio no Brasil.
          </p>
          <p>
            Reunimos dados de fontes oficiais — INEP, IBGE, MTE, OCDE e outras — em um único lugar, com camada analítica e editorial, para informar decisões de política pública, práticas pedagógicas e cobertura jornalística.
          </p>
          <p>
            Projeto de <strong class="text-primary">Marcelo Kanhan</strong>, executivo de comunicação, computational social scientist e pesquisador em tecnologia e inovação, com apoio institucional da <strong class="text-primary">Estácio</strong>.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
