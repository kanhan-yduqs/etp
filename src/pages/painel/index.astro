    <Container>
      <SectionHeader
        title="Painel de Indicadores Nacionais"
        subtitle="Exploração analítica dos dados da Educação Profissional e Tecnológica no Brasil."
      />

      <p class="text-on-surface-variant font-label text-sm">Gráficos interativos serão adicionados no Sprint 0D.</p>
    </Container>
  </section>
</BaseLayout>
