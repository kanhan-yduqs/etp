---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import BigNumber from '../../components/BigNumber.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SourceNote from '../../components/SourceNote.astro';
import FilterBar from '../../components/FilterBar.astro';
import ChoroplethMap from '../../components/charts/ChoroplethMap.astro';
import {
  getSerieTemporal,
  getMatriculasPorUF,
  getMatriculasPorModalidade,
  getLatestYear,
  formatNumber,
  formatPercent,
  calcGrowthPercent,
  MODALIDADE_LABELS,
  MODALIDADE_COLORS,
  getMetadata,
  getEmpregabilidadeSerie,
  getEmpregabilidadeLatest,
  formatCurrency,
} from '../../lib/data';

const serie = getSerieTemporal();
const latestYear = getLatestYear();
const latest = serie.find(s => s.ano === latestYear)!;
const previous = serie.find(s => s.ano === latestYear - 1)!;
const meta = getMetadata();

// Full datasets for client-side filtering
const allUFs = getMatriculasPorUF();
const allModalidades = getMatriculasPorModalidade();

// UF list for filter dropdown
const ufList = [...new Map(allUFs.map(u => [u.sigla_uf, { sigla: u.sigla_uf, nome: u.nome_uf }])).values()];

// Map data for latest year
const mapDataObj: Record<string, number> = {};
getMatriculasPorUF(latestYear).forEach(u => { mapDataObj[u.sigla_uf] = u.total; });

// Employment data
const empSerie = getEmpregabilidadeSerie();
const empLatest = getEmpregabilidadeLatest();

// Pre-built chart data for initial render (latest year)
const ufsTop10 = getMatriculasPorUF(latestYear).sort((a, b) => b.total - a.total).slice(0, 10);
---

<BaseLayout title="Painel de Indicadores" activePage="dados">
  <section class="py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Painel de Indicadores Nacionais"
        subtitle="Exploração analítica dos dados da Educação Profissional e Tecnológica no Brasil."
      />

      <!-- Big numbers -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <BigNumber
          value={formatNumber(latest.total)}
          label="Total Matrículas EPT"
          trend="up"
          trendValue={`+${formatPercent(calcGrowthPercent(latest.total, previous.total))} vs ${latestYear - 1}`}
          source={`Censo Escolar ${latestYear}`}
        />
        <BigNumber
          value={serie.length.toString()}
          label="Anos de Série Histórica"
          source={`${serie[0].ano}–${latestYear}`}
        />
        <BigNumber
          value={formatPercent((latest.publica / latest.total) * 100, 0)}
          label="Rede Pública"
          trend="up"
          trendValue="do total"
        />
      </div>

    </Container>
  </section>

  <!-- Mapa + Top UFs side-by-side com filtros -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Distribuição por Estado"
        subtitle="Explore as matrículas por UF. Clique no mapa para ver o perfil detalhado."
      />

      <!-- Filtros acima dos gráficos que controlam -->
      <FilterBar
        anos={meta.anos_cobertos}
        ufs={ufList}
        showUF={true}
        showRede={true}
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Mapa (esquerda) -->
        <div class="bg-surface-container-lowest p-4 rounded-xl">
          <ChoroplethMap mapId="painel-mapa" mapData={JSON.stringify(mapDataObj)} legendLabel="Matrículas" height="450px" />
        </div>

        <!-- Top 10 UFs (direita, filterable) -->
        <div class="bg-surface-container-lowest p-4 md:p-6 rounded-xl">
          <h3 class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-4">Top 10 Estados</h3>
          <div class="relative" style="height: 400px">
            <canvas id="chart-top-ufs"></canvas>
          </div>
        </div>
      </div>

      <SourceNote source="Sinopses Estatísticas — INEP/MEC" year={latestYear} />
    </Container>
  </section>

  <!-- Distribuição por Rede (filterable) -->
  <section class="bg-surface-container-low dark:bg-dark-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Distribuição por Rede"
        subtitle="Matrículas por dependência administrativa."
      />
      <div class="bg-surface-container-lowest dark:bg-dark-surface-container p-4 md:p-8 rounded-xl">
        <div class="relative" style="height: 350px">
          <canvas id="chart-por-rede"></canvas>
        </div>
      </div>
      <SourceNote source="Sinopses Estatísticas — INEP/MEC" year={latestYear} />
    </Container>
  </section>

  <!-- Modalidades ao longo do tempo -->
  <section class="py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Evolução por Modalidade"
        subtitle="Matrículas em cursos técnicos integrados, concomitantes, subsequentes e integrados à EJA."
      />
      <div class="bg-surface-container-lowest dark:bg-dark-surface-container p-4 md:p-8 rounded-xl">
        <div class="relative" style="height: 420px">
          <canvas id="chart-modalidades"></canvas>
        </div>
      </div>
      <SourceNote source="Sinopses Estatísticas — INEP/MEC" year={`${serie[0].ano}–${latestYear}`} />
    </Container>
  </section>

  <!-- Empregabilidade -->
  <section class="bg-surface-container-low dark:bg-dark-surface-container-low py-16 md:py-24">
    <Container>
      <SectionHeader
        title="Empregabilidade"
        subtitle="Inserção no mercado de trabalho formal de trabalhadores com ensino médio técnico."
        label="RAIS / MTE"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <BigNumber
          value={formatNumber(empLatest.empregados_tecnico)}
          label="Técnicos empregados"
          source={`RAIS ${empLatest.ano} (estimativa)`}
        />
        <BigNumber
          value={formatCurrency(empLatest.salario_medio_tecnico)}
          label="Salário médio técnico"
          trend="up"
          trendValue={`vs ${formatCurrency(empLatest.salario_medio_medio)} ensino médio`}
        />
        <BigNumber
          value={`+${empLatest.premio_salarial_pct}%`}
          label="Prêmio salarial"
          source="técnico vs ensino médio"
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-surface-container-lowest dark:bg-dark-surface-container p-4 md:p-8 rounded-xl">
          <h4 class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-4">Salário médio por escolaridade ({empLatest.ano})</h4>
          <div class="relative" style="height: 280px">
            <canvas id="chart-salarios"></canvas>
          </div>
        </div>
        <div class="bg-surface-container-lowest dark:bg-dark-surface-container p-4 md:p-8 rounded-xl">
          <h4 class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-4">Evolução do emprego técnico</h4>
          <div class="relative" style="height: 280px">
            <canvas id="chart-emprego-evolucao"></canvas>
          </div>
        </div>
      </div>

      <SourceNote source="Estimativas baseadas em RAIS/DIEESE" year={empLatest.ano} note="Dados aproximados para fins analíticos" />
    </Container>
  </section>

  <!-- Embedded full data for client-side filtering -->
  <script type="application/json" id="painel-data-ufs" set:html={JSON.stringify(allUFs)} />
  <script type="application/json" id="painel-data-serie" set:html={JSON.stringify(serie)} />
  <script type="application/json" id="painel-data-modalidades" set:html={JSON.stringify(allModalidades)} />
  <script type="application/json" id="painel-data-empregabilidade" set:html={JSON.stringify(empSerie)} />
</BaseLayout>

<script>
  import { Chart, BarController, BarElement, LineController, LineElement, PointElement, CategoryScale, LinearScale, Tooltip, Legend, Filler } from 'chart.js';
  import { registerChart } from '../../components/charts/ChartConfig';
  Chart.register(BarController, BarElement, LineController, LineElement, PointElement, CategoryScale, LinearScale, Tooltip, Legend, Filler);

  // Chart defaults
  Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#41484c';
  Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(0, 37, 50, 0.9)';
  Chart.defaults.plugins.tooltip.cornerRadius = 6;
  Chart.defaults.responsive = true;
  Chart.defaults.maintainAspectRatio = false;

  const MODALIDADE_LABELS: Record<string, string> = {
    integrada: 'Integrada ao EM',
    concomitante: 'Concomitante',
    subsequente: 'Subsequente',
    integrada_eja: 'Integrada à EJA',
  };
  // Read theme-aware colors from CSS custom properties
  const _styles = getComputedStyle(document.documentElement);
  const c1 = _styles.getPropertyValue('--chart-1').trim() || '#0D3B4C';
  const c2 = _styles.getPropertyValue('--chart-2').trim() || '#476800';
  const c3 = _styles.getPropertyValue('--chart-3').trim() || '#4a6d00';
  const c4 = _styles.getPropertyValue('--chart-4').trim() || '#2d6195';
  const c7 = _styles.getPropertyValue('--chart-7').trim() || '#8da1b9';
  const textColor = _styles.getPropertyValue('--chart-text').trim() || '#41484c';
  const gridColor = _styles.getPropertyValue('--chart-grid').trim() || 'rgba(0,0,0,0.04)';

  Chart.defaults.color = textColor;

  const MODALIDADE_COLORS: Record<string, string> = {
    integrada: c1,
    concomitante: c2,
    subsequente: c3,
    integrada_eja: c4,
  };

  // Load embedded data
  const allUFs = JSON.parse(document.getElementById('painel-data-ufs')?.textContent || '[]');
  const allSerie = JSON.parse(document.getElementById('painel-data-serie')?.textContent || '[]');
  const allModalidades = JSON.parse(document.getElementById('painel-data-modalidades')?.textContent || '[]');

  function formatNum(n: number): string {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace('.', ',') + 'M';
    if (n >= 1_000) return Math.round(n).toLocaleString('pt-BR');
    return n.toString();
  }

  function tooltipLabel(ctx: any, horizontal = false) {
    const val = ctx.parsed[horizontal ? 'x' : 'y'];
    return `${ctx.dataset.label}: ${formatNum(val)}`;
  }

  function tickFormat(value: any) {
    if (typeof value === 'number') {
      if (value >= 1_000_000) return (value / 1_000_000).toFixed(1) + 'M';
      if (value >= 1_000) return (value / 1_000).toFixed(0) + 'k';
    }
    return value;
  }

  // --- Chart instances ---
  let chartTopUFs: Chart | null = null;
  let chartPorRede: Chart | null = null;
  let chartModalidades: Chart | null = null;

  function buildCharts(ano: number, uf: string, rede: string) {
    // Filter UFs for selected year
    let ufsForYear = allUFs.filter((u: any) => u.ano === ano);

    // If specific UF selected, show only that
    if (uf !== 'todos') {
      ufsForYear = ufsForYear.filter((u: any) => u.sigla_uf === uf);
    }

    // Sort and take top 10
    const top10 = [...ufsForYear].sort((a: any, b: any) => b.total - a.total).slice(0, uf === 'todos' ? 10 : 1);

    // --- Top UFs chart ---
    const topUFsCanvas = document.getElementById('chart-top-ufs') as HTMLCanvasElement;
    if (chartTopUFs) chartTopUFs.destroy();
    chartTopUFs = new Chart(topUFsCanvas, {
      type: 'bar',
      data: {
        labels: top10.map((u: any) => u.sigla_uf),
        datasets: [{
          label: `Matrículas ${ano}`,
          data: top10.map((u: any) => rede === 'total' ? u.total : (u[rede] || 0)),
          backgroundColor: c1,
          borderRadius: 4,
        }],
      },
      options: {
        indexAxis: 'y',
        scales: {
          x: { ticks: { callback: tickFormat }, grid: { color: gridColor } },
          y: { grid: { color: gridColor } },
        },
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: (ctx: any) => tooltipLabel(ctx, true) } },
        },
      },
    });

    // --- Rede distribution chart ---
    // Aggregate across selected UFs
    const redeData = { federal: 0, estadual: 0, municipal: 0, privada: 0 };
    const ufsToSum = uf === 'todos' ? ufsForYear : ufsForYear;
    ufsToSum.forEach((u: any) => {
      redeData.federal += u.federal;
      redeData.estadual += u.estadual;
      redeData.municipal += u.municipal;
      redeData.privada += u.privada;
    });

    const redeCanvas = document.getElementById('chart-por-rede') as HTMLCanvasElement;
    if (chartPorRede) chartPorRede.destroy();
    chartPorRede = new Chart(redeCanvas, {
      type: 'bar',
      data: {
        labels: ['Federal', 'Estadual', 'Municipal', 'Privada'],
        datasets: [{
          label: `Matrículas ${ano}`,
          data: [redeData.federal, redeData.estadual, redeData.municipal, redeData.privada],
          backgroundColor: [c1, c2, c4, c7],
          borderRadius: 4,
        }],
      },
      options: {
        scales: {
          x: { grid: { color: gridColor } },
          y: { ticks: { callback: tickFormat }, grid: { color: gridColor } },
        },
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: (ctx: any) => tooltipLabel(ctx) } },
        },
      },
    });

    // --- Modalidades over time chart ---
    const anos = [...new Set(allModalidades.map((m: any) => m.ano))].sort() as number[];
    const modNames = ['integrada', 'concomitante', 'subsequente', 'integrada_eja'];

    const modCanvas = document.getElementById('chart-modalidades') as HTMLCanvasElement;
    if (chartModalidades) chartModalidades.destroy();
    chartModalidades = new Chart(modCanvas, {
      type: 'bar',
      data: {
        labels: anos.map(a => a.toString()),
        datasets: modNames.map(mod => ({
          label: MODALIDADE_LABELS[mod] || mod,
          data: anos.map(a => {
            const entry = allModalidades.find((m: any) => m.ano === a && m.modalidade === mod);
            return entry?.total || 0;
          }),
          backgroundColor: MODALIDADE_COLORS[mod] || '#71787c',
          borderRadius: 3,
        })),
      },
      options: {
        scales: {
          x: { grid: { color: gridColor } },
          y: { ticks: { callback: tickFormat }, grid: { color: gridColor } },
        },
        plugins: {
          legend: { position: 'bottom', labels: { usePointStyle: true, pointStyleWidth: 10, padding: 16 } },
          tooltip: { callbacks: { label: (ctx: any) => tooltipLabel(ctx) } },
        },
      },
    });
  }

  // Initial render
  const latestYear = Math.max(...allSerie.map((s: any) => s.ano));
  buildCharts(latestYear, 'todos', 'total');

  // Register filterable charts for theme updates
  if (chartTopUFs) registerChart(chartTopUFs);
  if (chartPorRede) registerChart(chartPorRede);
  if (chartModalidades) registerChart(chartModalidades);

  // Listen for filter changes
  document.addEventListener('filter-change', ((e: CustomEvent) => {
    const { ano, uf, rede } = e.detail;
    buildCharts(ano, uf, rede);
  }) as EventListener);

  // --- Employment charts (static, not filterable) ---
  // Reuses c1, c2, c7, gridColor, textColor from above
  const empData = JSON.parse(document.getElementById('painel-data-empregabilidade')?.textContent || '[]');

  if (empData.length > 0) {
    const empLatest = empData[empData.length - 1];

    // Salary comparison bar chart
    const salCanvas = document.getElementById('chart-salarios') as HTMLCanvasElement;
    if (salCanvas) {
      const salChart = new Chart(salCanvas, {
        type: 'bar',
        data: {
          labels: ['Ensino Médio', 'Ensino Técnico', 'Ensino Superior'],
          datasets: [{
            label: `Salário médio ${empLatest.ano}`,
            data: [empLatest.salario_medio_medio, empLatest.salario_medio_tecnico, empLatest.salario_medio_superior],
            backgroundColor: [c7, c2, c1],
            borderRadius: 4,
          }],
        },
        options: {
          color: textColor,
          scales: {
            x: { grid: { color: gridColor }, ticks: { color: textColor } },
            y: {
              grid: { color: gridColor },
              ticks: { color: textColor, callback: (v: any) => 'R$ ' + (v as number).toLocaleString('pt-BR') },
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx: any) => `R$ ${ctx.parsed.y.toLocaleString('pt-BR')}`,
              },
            },
          },
        },
      });
      registerChart(salChart);
    }

    // Employment evolution line chart
    const evoCanvas = document.getElementById('chart-emprego-evolucao') as HTMLCanvasElement;
    if (evoCanvas) {
      const evoChart = new Chart(evoCanvas, {
        type: 'line',
        data: {
          labels: empData.map((d: any) => d.ano.toString()),
          datasets: [{
            label: 'Técnicos empregados',
            data: empData.map((d: any) => d.empregados_tecnico),
            borderColor: c2,
            backgroundColor: 'rgba(71, 104, 0, 0.1)',
            fill: true,
            tension: 0.3,
            borderWidth: 2.5,
            pointRadius: 4,
            pointBackgroundColor: c2,
          }],
        },
        options: {
          color: textColor,
          scales: {
            x: { grid: { color: gridColor }, ticks: { color: textColor } },
            y: { grid: { color: gridColor }, ticks: { color: textColor, callback: (v: any) => formatNum(v as number) } },
          },
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx: any) => formatNum(ctx.parsed.y) + ' empregados' } },
          },
        },
      });
      registerChart(evoChart);
    }
  }
</script>
