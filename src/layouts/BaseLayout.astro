---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: 'dados' | 'politicas' | 'analises' | 'sobre' | 'comparacoes' | 'perfis' | 'guia';
}

const { title, description = 'Observatório Nacional do Ensino Técnico e Profissionalizante — dados, análises e comparações internacionais sobre a educação profissional no Brasil.', activePage } = Astro.props;
const fullTitle = title === 'Home' ? 'Observatório Nacional ETP' : `${title} — Observatório Nacional ETP`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Observatório Nacional ETP" />
  <meta property="og:locale" content="pt_BR" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <!-- Schema.org Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Observatório Nacional ETP",
    "url": Astro.site,
    "description": "Plataforma digital de referência sobre o Ensino Técnico e Profissionalizante no Brasil.",
    "founder": { "@type": "Person", "name": "Marcelo Kanhan" },
    "funder": [
      { "@type": "Organization", "name": "Instituto Yduqs" },
      { "@type": "Organization", "name": "Estácio" }
    ]
  })} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Pagefind CSS (loaded from dist after build) -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

  <!-- Prevent dark mode flash -->
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme');
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-surface dark:bg-dark-surface text-on-surface dark:text-dark-on-surface min-h-screen flex flex-col transition-colors duration-200">
  <Header activePage={activePage} />

  <main class="pt-20 flex-1" data-pagefind-body>
    <slot />
  </main>

  <Footer />
  <Search />
</body>
</html>
