---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: 'dados' | 'politicas' | 'analises' | 'sobre';
}

const { title, description = 'Observatório Nacional do Ensino Técnico e Profissionalizante — dados, análises e comparações internacionais sobre a educação profissional no Brasil.', activePage } = Astro.props;
const fullTitle = title === 'Home' ? 'Observatório Nacional ETP' : `${title} — Observatório Nacional ETP`;
---

<!DOCTYPE html>
<html lang="pt-BR" class="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">
  <Header activePage={activePage} />

  <main class="pt-20 flex-1">
    <slot />
  </main>

  <Footer />
</body>
</html>
