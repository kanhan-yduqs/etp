---
import PolicyStatusBadge from './PolicyStatusBadge.astro';

interface Props {
  title: string;
  status: 'ativa' | 'em-andamento' | 'encerrada';
  excerpt: string;
  href: string;
  progressLabel?: string;
  progressValue?: number;
}

const { title, status, excerpt, href, progressLabel, progressValue } = Astro.props;
---

<a href={href} class="group block bg-surface-container-lowest dark:bg-dark-surface-container p-6 rounded-xl hover:shadow-md transition-all">
  <PolicyStatusBadge status={status} />

  <h3 class="text-xl font-bold text-primary mt-3 group-hover:text-secondary transition-colors">{title}</h3>

  <p class="text-sm text-on-surface-variant mt-2 leading-relaxed">{excerpt}</p>

  {progressLabel && progressValue !== undefined && (
    <div class="mt-4">
      <div class="flex justify-between items-center mb-1">
        <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-wider">{progressLabel}</span>
        <span class="font-label text-xs font-semibold text-primary">{progressValue}%</span>
      </div>
      <div class="w-full bg-surface-container-high rounded-full h-1.5">
        <div class="bg-secondary h-1.5 rounded-full transition-all" style={`width: ${progressValue}%`}></div>
      </div>
    </div>
  )}
</a>
