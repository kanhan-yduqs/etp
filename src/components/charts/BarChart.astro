---
interface Props {
  chartId: string;
  chartData: string; // JSON serializado
  title?: string;
  horizontal?: boolean;
  height?: string;
}

const { chartId, chartData, title, horizontal = false, height = '400px' } = Astro.props;
---

<div class="relative" style={`height: ${height}`}>
  <canvas
    id={chartId}
    data-chart-type="bar"
    data-chart={chartData}
    data-horizontal={horizontal.toString()}
  ></canvas>
</div>

<script>
  import { Chart } from './ChartConfig';

  document.querySelectorAll<HTMLCanvasElement>('canvas[data-chart-type="bar"]').forEach(canvas => {
    const data = JSON.parse(canvas.dataset.chart || '{}');
    const horizontal = canvas.dataset.horizontal === 'true';
    const styles = getComputedStyle(document.documentElement);
    const gridColor = styles.getPropertyValue('--chart-grid').trim() || 'rgba(0,0,0,0.04)';
    const gridColorStrong = styles.getPropertyValue('--chart-grid-strong').trim() || 'rgba(0,0,0,0.06)';
    const textColor = styles.getPropertyValue('--chart-text').trim() || '#41484c';

    // Override dataset colors with current theme's CSS variables
    const chartColors = Array.from({length: 8}, (_, i) =>
      styles.getPropertyValue(`--chart-${i + 1}`).trim()
    ).filter(c => c);
    if (chartColors.length && data.datasets) {
      data.datasets.forEach((ds: any, i: number) => {
        if (Array.isArray(ds.backgroundColor)) {
          // Multi-color bars (e.g., one color per bar) — replace each
          ds.backgroundColor = ds.backgroundColor.map((_: any, j: number) =>
            chartColors[j % chartColors.length]
          );
        } else {
          ds.backgroundColor = chartColors[i % chartColors.length];
        }
      });
    }

    const formatTick = (value: any) => {
      if (typeof value === 'number') {
        if (value >= 1_000_000) return (value / 1_000_000).toFixed(1) + 'M';
        if (value >= 1_000) return (value / 1_000).toFixed(0) + 'k';
      }
      return value;
    };

    // Override global default color for this chart instance (dark mode support)
    Chart.defaults.color = textColor;

    new Chart(canvas, {
      type: 'bar',
      data: data,
      options: {
        indexAxis: horizontal ? 'y' : 'x',
        color: textColor,
        scales: {
          x: {
            grid: { color: horizontal ? gridColorStrong : gridColor },
            ticks: horizontal ? { callback: formatTick, color: textColor } : { color: textColor },
          },
          y: {
            grid: { color: horizontal ? gridColor : gridColorStrong },
            ticks: horizontal ? { color: textColor } : { callback: formatTick, color: textColor },
          },
        },
        plugins: {
          legend: { position: 'bottom', labels: { color: textColor } },
          tooltip: {
            callbacks: {
              label: function(ctx: any) {
                const val = ctx.parsed[horizontal ? 'x' : 'y'];
                const formatted = val >= 1_000_000
                  ? (val / 1_000_000).toFixed(2).replace('.', ',') + 'M'
                  : val.toLocaleString('pt-BR');
                return `${ctx.dataset.label}: ${formatted}`;
              }
            }
          }
        },
      },
    });
  });
</script>
