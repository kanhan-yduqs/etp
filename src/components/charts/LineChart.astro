---
interface Props {
  chartId: string;
  chartData: string; // JSON serializado
  title?: string;
  xLabel?: string;
  yLabel?: string;
  height?: string;
}

const { chartId, chartData, title, xLabel, yLabel, height = '400px' } = Astro.props;
---

<div class="relative" style={`height: ${height}`}>
  <canvas id={chartId} data-chart-type="line" data-chart={chartData} data-x-label={xLabel} data-y-label={yLabel}></canvas>
</div>

<script>
  import { Chart } from './ChartConfig';

  document.querySelectorAll<HTMLCanvasElement>('canvas[data-chart-type="line"]').forEach(canvas => {
    const data = JSON.parse(canvas.dataset.chart || '{}');
    const xLabel = canvas.dataset.xLabel;
    const yLabel = canvas.dataset.yLabel;
    const styles = getComputedStyle(document.documentElement);
    const gridColor = styles.getPropertyValue('--chart-grid').trim() || 'rgba(0,0,0,0.04)';
    const gridColorStrong = styles.getPropertyValue('--chart-grid-strong').trim() || 'rgba(0,0,0,0.06)';
    const textColor = styles.getPropertyValue('--chart-text').trim() || '#41484c';

    // Override dataset colors with current theme's CSS variables
    const chartColors = Array.from({length: 8}, (_, i) =>
      styles.getPropertyValue(`--chart-${i + 1}`).trim()
    ).filter(c => c);
    if (chartColors.length && data.datasets) {
      data.datasets.forEach((ds: any, i: number) => {
        const color = chartColors[i % chartColors.length];
        if (color) {
          ds.borderColor = color;
          ds.pointBackgroundColor = color;
          ds.backgroundColor = color.replace(')', ', 0.1)').replace('rgb', 'rgba').replace('#', '');
          // For hex colors, create transparent version
          if (color.startsWith('#')) {
            const r = parseInt(color.slice(1,3), 16);
            const g = parseInt(color.slice(3,5), 16);
            const b = parseInt(color.slice(5,7), 16);
            ds.backgroundColor = `rgba(${r},${g},${b},0.1)`;
          }
        }
      });
    }

    // Override global default color for this chart instance (dark mode support)
    Chart.defaults.color = textColor;

    new Chart(canvas, {
      type: 'line',
      data: data,
      options: {
        interaction: { mode: 'index', intersect: false },
        color: textColor,
        scales: {
          x: {
            title: xLabel ? { display: true, text: xLabel, font: { family: "'Space Grotesk'" }, color: textColor } : { display: false },
            grid: { color: gridColor },
            ticks: { color: textColor },
          },
          y: {
            title: yLabel ? { display: true, text: yLabel, font: { family: "'Space Grotesk'" }, color: textColor } : { display: false },
            grid: { color: gridColorStrong },
            ticks: {
              color: textColor,
              callback: function(value: any) {
                if (typeof value === 'number') {
                  if (value >= 1_000_000) return (value / 1_000_000).toFixed(1) + 'M';
                  if (value >= 1_000) return (value / 1_000).toFixed(0) + 'k';
                }
                return value;
              }
            }
          },
        },
        plugins: {
          legend: { position: 'bottom', labels: { color: textColor } },
          tooltip: {
            callbacks: {
              label: function(ctx: any) {
                const val = ctx.parsed.y;
                const formatted = val >= 1_000_000
                  ? (val / 1_000_000).toFixed(2).replace('.', ',') + 'M'
                  : val.toLocaleString('pt-BR');
                return `${ctx.dataset.label}: ${formatted}`;
              }
            }
          }
        },
      },
    });
  });
</script>
