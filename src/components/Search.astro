---
// Pagefind search modal - loaded lazily on demand
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-primary-deep/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative max-w-2xl mx-auto mt-20 px-4">
    <div class="bg-surface dark:bg-dark-surface rounded-xl shadow-2xl overflow-hidden">
      <div class="flex justify-between items-center px-6 py-4 bg-surface-container-low dark:bg-dark-surface-container-low">
        <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Buscar no Observatório</span>
        <button id="search-close" class="text-on-surface-variant hover:text-primary p-1" aria-label="Fechar busca">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="search-container" class="p-6"></div>
    </div>
  </div>
</div>

<script is:inline>
  let pagefindLoaded = false;

  async function openSearch() {
    const modal = document.getElementById('search-modal');
    modal?.classList.remove('hidden');

    if (!pagefindLoaded) {
      try {
        // Dynamic import — Pagefind files only exist after build
        const pagefind = await import('/pagefind/pagefind-ui.js');
        new pagefind.PagefindUI({
          element: '#search-container',
          showSubResults: true,
          translations: {
            placeholder: 'Buscar dados, análises, políticas...',
            zero_results: 'Nenhum resultado para "[SEARCH_TERM]"',
          },
        });
        pagefindLoaded = true;
      } catch {
        const container = document.getElementById('search-container');
        if (container) container.innerHTML = '<p class="text-on-surface-variant text-sm">Busca disponível apenas no site publicado (após build).</p>';
      }
    }

    // Focus the input
    setTimeout(() => {
      const input = document.querySelector<HTMLInputElement>('#search-container input');
      input?.focus();
    }, 100);
  }

  function closeSearch() {
    document.getElementById('search-modal')?.classList.add('hidden');
  }

  // Open from header button
  document.getElementById('search-trigger')?.addEventListener('click', openSearch);
  // Close
  document.getElementById('search-close')?.addEventListener('click', closeSearch);
  document.getElementById('search-backdrop')?.addEventListener('click', closeSearch);
  // Esc key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if (e.key === '/' && !['INPUT', 'TEXTAREA'].includes((e.target as HTMLElement)?.tagName)) {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style is:global>
  /* Pagefind UI overrides to match design system */
  .pagefind-ui__search-input {
    font-family: 'Inter', system-ui, sans-serif !important;
    border: none !important;
    border-bottom: 2px solid #c1c7cc !important;
    border-radius: 0 !important;
    padding: 8px 0 !important;
    font-size: 16px !important;
    background: transparent !important;
  }
  .pagefind-ui__search-input:focus {
    border-bottom-color: #0D3B4C !important;
    outline: none !important;
    box-shadow: none !important;
  }
  .pagefind-ui__result-link {
    color: #0D3B4C !important;
    font-weight: 600 !important;
  }
  .pagefind-ui__result-excerpt {
    font-size: 14px !important;
    color: #41484c !important;
  }
  .pagefind-ui__button {
    background: #0D3B4C !important;
    color: white !important;
    border-radius: 6px !important;
  }
</style>
