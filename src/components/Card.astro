---
interface Props {
  title?: string;
  href?: string;
}

const { title, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  class:list={[
    'block bg-surface-container-lowest p-6 md:p-8 rounded-xl transition-shadow',
    href && 'hover:shadow-md cursor-pointer'
  ]}
  href={href}
>
  {title && (
    <h3 class="text-lg font-semibold text-primary mb-4">{title}</h3>
  )}
  <slot />
</Tag>
