---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  id?: string;
}

const { title, subtitle, label, id } = Astro.props;
---

<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 gap-4 md:gap-8" id={id}>
  <div>
    {label && (
      <span class="font-label text-xs font-medium uppercase tracking-[0.2em] text-on-surface-variant">{label}</span>
    )}
    <h2 class="text-3xl md:text-4xl font-bold mt-2 text-primary">{title}</h2>
    {subtitle && (
      <p class="mt-3 text-on-surface-variant text-base md:text-lg max-w-2xl leading-relaxed">{subtitle}</p>
    )}
  </div>
  <slot />
</div>
