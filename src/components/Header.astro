---
interface Props {
  activePage?: 'dados' | 'politicas' | 'analises' | 'sobre' | 'comparacoes' | 'perfis';
}

const { activePage } = Astro.props;

const navItems = [
  { id: 'dados', label: 'Dados', href: '/painel/' },
  { id: 'politicas', label: 'Políticas', href: '/politicas/' },
  { id: 'analises', label: 'Análises', href: '/analises/' },
  { id: 'sobre', label: 'Sobre', href: '/sobre/' },
] as const;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface dark:bg-primary-deep transition-colors duration-200">
  <div class="flex justify-between items-center w-full px-6 md:px-8 py-4 max-w-[1440px] mx-auto">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-bold tracking-tighter text-primary dark:text-surface">
        Observatório Nacional ETP
      </a>
      <nav class="hidden md:flex gap-6 items-center">
        {navItems.map(item => (
          <a
            class:list={[
              'font-display font-semibold text-sm tracking-tight transition-colors duration-200',
              activePage === item.id
                ? 'text-primary dark:text-surface border-b-2 border-secondary pb-1'
                : 'text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-surface'
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="flex items-center gap-2">
      <!-- Search trigger -->
      <button
        id="search-trigger"
        class="p-2 hover:bg-surface-container-low dark:hover:bg-primary-container rounded-full transition-colors"
        aria-label="Buscar (pressione /)"
      >
        <svg class="w-5 h-5 text-primary dark:text-surface" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-2 hover:bg-surface-container-low dark:hover:bg-primary-container rounded-full transition-colors"
        aria-label="Alternar tema"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-5 h-5 text-primary dark:text-surface hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-5 h-5 text-primary dark:text-surface block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 hover:bg-surface-container-low dark:hover:bg-primary-container rounded-full transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6 text-primary dark:text-surface" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Subtle separator (no 1px border — tonal shift per design system) -->
  <div class="bg-surface-container-low dark:bg-primary-container h-[1px] w-full"></div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-surface dark:bg-primary-deep border-t border-surface-container-low">
    <div class="px-6 py-4 space-y-3">
      {navItems.map(item => (
        <a
          class:list={[
            'block py-2 font-display font-semibold text-sm',
            activePage === item.id
              ? 'text-primary dark:text-surface'
              : 'text-on-surface-variant dark:text-outline-variant'
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Dark mode toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    html.classList.toggle('dark', !isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });
</script>
